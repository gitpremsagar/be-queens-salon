DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Refresh token cookie
REFRESH_TOKEN_COOKIE_NAME=refreshToken
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=604800000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# CORS
CLIENT_ORIGIN=http://localhost:3000
# Admin seed
ADMIN_EMAIL=admin@queensbeauty.salon
ADMIN_PASSWORD=AdminPass123!

# Salon
SALON_OPEN_TIME=10:00
SALON_CLOSE_TIME=19:00
SALON_SLOT_INTERVAL_MINUTES=30
SALON_CLOSED_WEEKDAYS=0
SALON_TIMEZONE=Asia/Kolkata
SALON_PHONE=+91 98765 43210
SALON_EMAIL=hello@queensbeauty.salon
SALON_ADDRESS=12 Rosewood Lane, Bandra West, Mumbai 400050
